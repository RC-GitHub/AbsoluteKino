{
  "compilerOptions": {
    "target": "es6",                          
    "module": "commonjs",                     
    "strict": true,      
    "allowJs": true,  
    "checkJs": false,                   
    "esModuleInterop": true,                  
    "skipLibCheck": true,                     
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
  },
  "include": ["*.ts", "src/server.ts"],                         
  "exclude": ["node_modules"]                  
}